{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SARP User Inputs Schema",
  "type": "object",
  "required": ["main", "outfile", "flags"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "main": {
      "type": "array",
      "description": "Main body of inputs",
      "items": {
        "type": "object",
        "required": ["scanner", "path", "remove", "prepend"],
        "properties": {
          "scanner": {
            "type": "string",
            "description": "Name and version of the scanner"
          },
          "path": {
            "type": "string",
            "description": "Path to the input file"
          },
          "remove": {
            "type": "string",
            "description": "String to remove from paths"
          },
          "prepend": {
            "type": "string",
            "description": "String to prepend to paths"
          }
        },
        "additionalProperties": false
      }
    },
    "outfile": {
      "type": "string",
      "pattern": ".*\\.(xlsx|csv)$",
      "description": "Output file path (.xlsx or .csv only)"
    },
    "flags": {
      "type": "object",
      "required": [
        "Category Mappings",
        "Preflight Rules",
        "Default Preflight Rules"
      ],
      "properties": {
        "Category Mappings": {
          "type": "boolean",
          "description": "True: Appends \":CATEGORY\", \":DISCOURAGED\", etc. to the end of CWE numbers"
        },
        "Preflight Rules": {
          "type": "boolean",
          "description": "True: Changes final output values according to user-defined rules"
        },
        "Default Preflight Rules": {
          "type": "boolean",
          "description": "True: Changes final output values according to a default profile of rules. Only activated if \"Preflight Rules\" flag is also true."
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
